---
---
<div id="tsparticles"></div>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadSlim } from "@tsparticles/slim";

  async function loadParticles() {
    await loadSlim(tsParticles);

    // Initial color matching the current theme or defaulting to dark
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
    const pColor = currentTheme === 'dark' ? '#ffffff' : '#000000';

    await tsParticles.load({
      id: "tsparticles",
      options: {
        background: { color: 'transparent' },
        fpsLimit: 60,
        interactivity: {
          events: {
            onClick: { enable: true, mode: 'push' },
            onHover: { enable: true, mode: 'repulse' },
          },
          modes: {
            push: { quantity: 4 },
            repulse: { distance: 100, duration: 0.4 },
          },
        },
        particles: {
          color: { value: pColor },
          links: {
            color: pColor,
            distance: 150,
            enable: true,
            opacity: 0.5,
            width: 1,
          },
          collisions: { enable: true },
          move: {
            direction: 'none',
            enable: true,
            outModes: { default: 'bounce' },
            random: false,
            speed: 2,
            straight: false,
          },
          number: {
            density: { enable: true },
            value: 150,
          },
          opacity: { value: 0.4 },
          shape: { type: 'circle' },
          size: { value: { min: 1, max: 3 } },
        },
        detectRetina: true,
      }
    });
  }

  loadParticles();

  // Handle theme changes using a MutationObserver
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        const newTheme = document.documentElement.getAttribute('data-theme');
        const newColor = newTheme === 'dark' ? '#ffffff' : '#000000';
        const container = tsParticles.domItem(0);
        if (container) {
          container.options.particles.color.value = newColor;
          container.options.particles.links.color = newColor;
          container.refresh();
        }
      }
    });
  });

  observer.observe(document.documentElement, { attributes: true });
</script>

<style>
  #tsparticles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }
</style>
